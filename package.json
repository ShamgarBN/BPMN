{
  "name": "bpmn-studio",
  "private": true,
  "version": "1.1.0",
  "description": "Build BPMN 2.0 process diagrams with guided forms or natural language. Runs entirely on your machine.",
  "author": {
    "name": "BPMN Studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShamgarBN/BPMN.git"
  },
  "bugs": {
    "url": "https://github.com/ShamgarBN/BPMN/issues"
  },
  "homepage": "https://github.com/ShamgarBN/BPMN#readme",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "ELECTRON=1 vite",
    "electron:build": "tsc -b && ELECTRON=1 vite build",
    "electron:pack": "npm run electron:build && electron-builder --dir",
    "electron:dist": "npm run electron:build && electron-builder",
    "electron:dist:mac": "npm run electron:build && electron-builder --mac",
    "electron:dist:win": "npm run electron:build && electron-builder --win",
    "electron:dist:linux": "npm run electron:build && electron-builder --linux",
    "guide:install": "node scripts/generate-install-guide.mjs",
    "icons:build": "node scripts/build-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node scripts/run-smoke.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bpmn-auto-layout": "^1.3.0",
    "bpmn-js": "^18.16.1",
    "bpmn-moddle": "^10.0.0",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "svg2pdf.js": "^2.7.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xmldom/xmldom": "^0.9.10",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "png2icons": "^2.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.1.7"
  }
}
